# ============================================
# Built at GrowthX - Environment Variables
# ============================================
# Copy this file to .env:
#   cp .env.example .env

# --- Mock Mode (for contributors) ---
# Set to "true" to run the app with seed data, no backend needed.
VITE_MOCK_MODE=true

# --- API base (optional) ---
# Defaults to http://localhost:8000/api/v1 when unset.
# VITE_API_URL=http://localhost:8000/api/v1
